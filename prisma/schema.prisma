// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------- Auth Models -------------------

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum Department {
  SALES
  DEVELOPMENT
  DESIGN
  SEO
  MARKETING
  HR
  OPERATIONS
}

model User {
  id                 String             @id
  name               String
  email              String
  emailVerified      Boolean            @default(false)
  image              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  role               UserRole           @default(STAFF)
  department         Department?
  banned             Boolean?           @default(false)
  banReason          String?
  banExpires         DateTime?
  sessions           Session[]
  accounts           Account[]
  assignedCustomers  Customer[]         @relation("AssignedCustomers")
  createdCustomers   Customer[]         @relation("CreatedCustomers")
  proposalActivities ProposalActivity[]
  proposals          Proposal[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ------------------- Auth Models End -------------------

enum CustomerSource {
  WEBSITE
  GOOGLE
  REFERRAL
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  MANUAL
  OTHER
}

enum CustomerType {
  BUSINESS
  INDIVIDUAL
}

model Customer {
  id String @id @default(cuid())

  customerNumber      Int     @unique @default(autoincrement())
  displayName         String
  companyName         String?
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  website             String?
  addressLine1        String?
  addressLine2        String?

  billingAddressLine1 String?
  billingAddressLine2 String?

  billingCity       String?
  billingState      String?
  billingCountry    String?
  billingPostalCode String?

  city          String?
  state         String?
  country       String?
  postalCode    String?
  gstNumber     String?
  panNumber     String?
  internalNotes String?
  source        CustomerSource?
  customerType  CustomerType    @default(BUSINESS)

  assignedToId String?
  createdById  String?
  assignedTo   User?   @relation("AssignedCustomers", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User?   @relation("CreatedCustomers", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  lastActivityAt   DateTime?
  customerContacts CustomerContact[]
  proposals        Proposal[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([deletedAt])
}

model CustomerContact {
  id String @id @default(cuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  name        String
  designation String?

  email String?
  phone String?

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([customerId])
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

model Service {
  id String @id @default(cuid())

  name String
  slug String @unique

  description String?

  isActive Boolean @default(true)

  packages ServicePackage[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  proposalTermServices ProposalTermService[]

  @@index([isActive])
}

model ServicePackage {
  id String @id @default(cuid())

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name String

  description String?

  isPopular Boolean @default(false)
  isActive  Boolean @default(true)

  totalPrice Decimal @default(0) @db.Decimal(12, 2)

  items    ServicePackageItem[]
  features PackageFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([isActive])
}

model ServicePackageItem {
  id String @id @default(cuid())

  packageId String

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  name        String
  description String?

  quantity Int @default(1)

  unitPrice Decimal @db.Decimal(12, 2)

  unit String

  billingCycle BillingCycle

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
}

model PackageFeature {
  id String @id @default(cuid())

  packageId String
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  content String

  sortOrder Int @default(0)
}

model ProposalTerm {
  id String @id @default(cuid())

  title String

  content Json

  isDefault Boolean @default(false)

  isActive Boolean @default(true)

  services ProposalTermService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProposalTermService {
  termId     String
  serviceId  String
  sortOrder  Int     @default(0)
  isRequired Boolean @default(true)

  term ProposalTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([termId, serviceId])
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Proposal {
  id String @id @default(cuid())

  proposalNumber Int @unique @default(autoincrement())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  preparedById String
  preparedBy   User   @relation(fields: [preparedById], references: [id])

  customerDisplayName String
  customerCompanyName String?
  preparedByName      String

  title String

  status ProposalStatus @default(DRAFT)

  validUntil DateTime?

  currency String @default("INR")

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposalBlocks     ProposalBlock[]
  proposalActivities ProposalActivity[]

  @@index([customerId])
  @@index([status])
}

enum ProposalBlockType {
  SECTION
  SERVICE
  PRICING_SUMMARY
}

model ProposalBlock {
  id String @id @default(cuid())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  type ProposalBlockType

  sortOrder Int

  title String?

  content Json?

  service ProposalService?

  createdAt DateTime @default(now())

  @@index([proposalId])
}

model ProposalService {
  id String @id @default(cuid())

  blockId String @unique

  block ProposalBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  serviceName String

  packageName String?

  description String?

  notes String?

  items ProposalLineItem[]

  features ProposalFeature[]
}

model ProposalLineItem {
  id String @id @default(cuid())

  proposalServiceId String

  proposalService ProposalService @relation(fields: [proposalServiceId], references: [id], onDelete: Cascade)

  name String

  description String?

  quantity Int

  unit String

  unitPrice Decimal @db.Decimal(12, 2)

  billingCycle BillingCycle

  sortOrder Int

  createdAt DateTime @default(now())

  @@index([proposalServiceId])
}

model ProposalFeature {
  id String @id @default(cuid())

  proposalServiceId String

  proposalService ProposalService @relation(fields: [proposalServiceId], references: [id], onDelete: Cascade)

  content String

  sortOrder Int

  @@index([proposalServiceId])
}

enum ProposalActivityType {
  CREATED
  UPDATED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model ProposalActivity {
  id String @id @default(cuid())

  proposalId String

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  userId String

  user User @relation(fields: [userId], references: [id])

  action ProposalActivityType

  createdAt DateTime @default(now())

  @@index([proposalId])
}
